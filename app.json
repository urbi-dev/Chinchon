{
  "expo": {
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#22c55e",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true
    },
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true
    },
    "name": "chinchon-calc",
    "newArchEnabled": true,
    "orientation": "portrait",
    "slug": "chinchon-calc",
    "splash": {
      "backgroundColor": "#ffffff",
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain"
    },
    "userInterfaceStyle": "light",
    "version": "1.0.4",
    "web": {
      "favicon": "./public/favicon.png",
      "manifest": {
        "background_color": "#ffffff",
        "description": "Calculadora de puntuaciones para el juego de cartas Chinchón",
        "display": "standalone",
        "icons": [
          {
            "sizes": "192x192",
            "src": "./assets/web-icons/icon-192.png",
            "type": "image/png"
          },
          {
            "sizes": "512x512",
            "src": "./assets/web-icons/icon-512.png",
            "type": "image/png"
          },
          {
            "purpose": "any maskable",
            "sizes": "180x180",
            "src": "./assets/web-icons/icon-180.png",
            "type": "image/png"
          }
        ],
        "name": "Chinchón Calc",
        "orientation": "portrait",
        "scope": "/",
        "short_name": "Chinchón",
        "start_url": "/",
        "theme_color": "#22c55e"
      },
      "output": {
        "publicPath": ""
      }
    }
  }
}